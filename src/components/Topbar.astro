---

<header class="bg-background docked full-width top-0 h-16 border-b border-outline-variant flex justify-between items-center px-container-margin sticky z-40">
    <!-- Search Bar (on_left) -->
    <div class="flex items-center gap-base bg-surface-container border border-outline-variant rounded-full px-4 py-2 w-96 focus-within:border-primary-fixed transition-colors">
        <span class="material-symbols-outlined text-on-surface-variant text-sm">search</span>
        <input class="bg-transparent border-none text-body-md font-body-md text-on-surface placeholder-on-surface-variant focus:outline-none focus:ring-0 w-full p-0 ml-2" placeholder="Buscar miembro, clase o transacción..." type="text"/>
    </div>
    
    <!-- Trailing Actions -->
    <div class="flex items-center gap-stack-md">
        <!-- Secondary Action -->
        <a href="/finanzas" class="px-4 py-2 bg-surface border border-outline-variant text-on-surface hover:text-primary-fixed transition-colors font-label-caps text-label-caps rounded-lg cursor-pointer active:opacity-80 uppercase tracking-wider text-center">
            Reportes
        </a>
        
        <!-- Primary Action -->
        <a href="/nuevo-miembro" class="px-4 py-2 bg-primary-fixed text-on-primary-fixed font-label-caps text-label-caps rounded-lg hover:brightness-110 transition-colors cursor-pointer active:opacity-80 uppercase tracking-wider font-bold text-center">
            Nuevo Miembro
        </a>
        
        <!-- Icon Actions -->
        <div class="flex items-center gap-2 ml-4 border-l border-outline-variant pl-4">
            <button class="text-on-surface-variant hover:text-primary-fixed transition-colors p-2 rounded-full hover:bg-surface-container-highest cursor-pointer">
                <span class="material-symbols-outlined">notifications</span>
            </button>
            <button class="text-on-surface-variant hover:text-primary-fixed transition-colors p-2 rounded-full hover:bg-surface-container-highest cursor-pointer">
                <span class="material-symbols-outlined">help_outline</span>
            </button>
        </div>
        
        <!-- Profile Image -->
        <div class="w-10 h-10 rounded-full bg-surface-variant ml-2 overflow-hidden border-2 border-outline-variant cursor-pointer">
            <img alt="Administrator Avatar" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAZur9B8gHO9i7I4GKbaNq_QI6fBlu6zo5c4xBMDhltBTm4lwKNxYPpgJWUWaetOwiuqdYo81PWWQzsmDCJHHslJZM9lJqLfdLq24I71OLV6aZqqN0z51h7lHO63OwdSx7JqhuJVQO-_j4ZgqDkViY52Y5eaL3c7THBsQfkYxdLnZ8FCozPS6U1fBqiklMn31_saOPnJzaPGq2PUdnX3ss5YP0EkkF4peAwTvEJTjNInxv3KTjxC0rbNMi6yAyLjc9DjgIEe7YeKMc"/>
        </div>
    </div>
</header>
