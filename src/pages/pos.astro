---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Punto de Venta">
    <div class="flex h-[calc(100vh-64px)] -m-6"> 
        <!-- Main Content Canvas (Reports & POS Products) -->
        <div class="flex-1 overflow-y-auto p-container-margin flex flex-col gap-stack-xl">
            <!-- POS Products Section -->
            <section class="flex-1 flex flex-col pb-stack-lg">
                <div class="flex justify-between items-center border-b border-outline-variant pb-2 mb-stack-md">
                    <h2 class="font-headline-md text-headline-md text-on-background">Punto de Venta</h2>
                    <div class="flex items-center gap-4">
                        <div class="flex gap-4" id="pos-tabs">
                            <button data-tab="membresias" class="tab-btn font-label-caps text-label-caps text-primary-fixed border-b-2 border-primary-fixed pb-2 px-2">Membresías</button>
                            <button data-tab="otros" class="tab-btn font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface pb-2 px-2 transition-colors border-b-2 border-transparent">Productos</button>
                        </div>
                        <div class="ml-4 pl-4 border-l border-outline-variant flex gap-2">
                            <button id="btn-nuevo-producto" class="font-label-caps text-label-caps bg-surface-container-highest text-primary-fixed border border-primary-fixed/30 rounded-lg px-4 py-2 hover:bg-surface-variant transition-colors flex items-center gap-2 cursor-pointer">
                                <span class="material-symbols-outlined text-[16px]">add</span>
                                Nuevo Producto
                            </button>
                            <button id="btn-productos-inactivos" class="font-label-caps text-label-caps bg-surface-container-highest text-on-surface-variant border border-outline-variant rounded-lg px-4 py-2 hover:bg-surface-variant transition-colors flex items-center gap-2 cursor-pointer">
                                <span class="material-symbols-outlined text-[16px]">archive</span>
                                Archivados
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Barra de búsqueda local (solo visible en tab Productos) -->
                <div id="productos-search-bar" class="hidden mb-stack-md">
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px] pointer-events-none">search</span>
                        <input
                            type="text"
                            id="productos-search-input"
                            placeholder="Buscar por nombre o categoría..."
                            class="w-full bg-surface-container-highest border border-outline-variant rounded-lg pl-10 pr-4 py-2 text-sm text-on-surface placeholder-on-surface-variant focus:outline-none focus:border-primary-fixed transition-colors"
                        />
                    </div>
                </div>

                <!-- Loader -->
                <div id="loading-pos" class="py-12 flex justify-center hidden">
                    <span class="material-symbols-outlined animate-spin text-primary-fixed text-4xl">progress_activity</span>
                </div>

                <!-- Dynamic Grid for Membresias (Solo Vista) -->
                <div id="membresias-grid" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter overflow-y-auto">
                    <!-- Loaded dynamically -->
                </div>

                <!-- Static Grid for Productos (Solo para visualización extra en mockup) -->
                <div id="otros-grid" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter overflow-y-auto hidden">
                    <div class="bg-surface-container rounded-xl border border-outline-variant p-4 flex flex-col hover:border-primary-fixed/50 transition-colors group">
                        <div class="h-32 bg-surface-container-highest rounded-lg mb-4 overflow-hidden relative">
                            <div class="w-full h-full bg-[#1A1A1A] flex items-center justify-center">
                                <span class="material-symbols-outlined text-outline-variant text-3xl">image</span>
                            </div>
                        </div>
                        <h3 class="font-data-table text-data-table text-on-surface mb-1">Whey Protein Isolate</h3>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex-1">Sabor Vainilla - 2kg</p>
                        <div class="flex justify-between items-center mt-auto">
                            <span class="font-headline-md text-headline-md text-primary-fixed">$1,200</span>
                            <button class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors">
                                <span class="material-symbols-outlined text-[18px]">add</span>
                            </button>
                        </div>
                    </div>
                </div>

            </section>
        </div>
        
        <!-- Right Sidebar: Shopping Cart / Checkout -->
        <aside class="w-96 min-w-[384px] border-l border-outline-variant bg-surface-container flex flex-col z-10 shadow-[-10px_0_30px_rgba(0,0,0,0.5)]">
            <!-- Cart Header -->
            <div class="px-4 py-3 border-b border-outline-variant flex justify-between items-center">
                <h2 class="font-title-md text-title-md text-on-background">Carrito Actual</h2>
                <span id="cart-item-count" class="bg-primary-container/20 text-primary-fixed px-2 py-0.5 rounded font-label-caps text-label-caps">0 Items</span>
            </div>

            <!-- Customer Selector -->
            <div class="px-4 py-3 border-b border-outline-variant space-y-1.5">
                <span class="font-label-caps text-[10px] text-on-surface-variant block">Cliente</span>
                <div class="flex gap-2">
                    <input type="text" id="member-search-input" placeholder="ID de Socio (Opcional)" class="flex-1 bg-surface-container-highest border border-outline-variant rounded px-3 py-1.5 text-xs text-on-surface focus:outline-none focus:border-primary-fixed" />
                    <button id="btn-search-member" class="bg-surface-container-highest border border-outline-variant hover:border-primary-fixed text-on-surface px-3 py-1.5 rounded transition-colors flex items-center justify-center cursor-pointer">
                        <span class="material-symbols-outlined text-[16px]">search</span>
                    </button>
                </div>
                <div id="selected-member-info" class="text-xs text-primary-fixed hidden flex items-center justify-between bg-primary-container/10 p-2 rounded border border-primary-fixed/20 mt-2">
                    <div>
                        <p class="font-bold" id="selected-member-name">Juan Pérez</p>
                        <p class="text-[10px] text-on-surface-variant" id="selected-member-id-display">Socio #123</p>
                    </div>
                    <button id="btn-clear-member" class="text-error hover:text-error/80 cursor-pointer bg-transparent border-0 p-0 flex items-center">
                        <span class="material-symbols-outlined text-[16px]">cancel</span>
                    </button>
                </div>
            </div>

            <!-- Cart Items List -->
            <div id="cart-items-container" class="flex-1 overflow-y-auto min-h-0 p-4 space-y-3 custom-scrollbar">
                <!-- Loaded dynamically -->
                <div class="text-center text-on-surface-variant py-8 font-body-md">
                    <span class="material-symbols-outlined text-4xl block mb-2 text-outline-variant">shopping_cart</span>
                    El carrito está vacío
                </div>
            </div>

            <!-- Checkout Section -->
            <div class="p-4 border-t border-outline-variant bg-surface-container-low shrink-0">
                <!-- Totals -->
                <div class="space-y-1 mb-3">
                    <div class="flex justify-between font-body-sm text-body-sm text-on-surface-variant">
                        <span>Subtotal</span>
                        <span id="cart-subtotal">$0.00</span>
                    </div>
                    <div class="flex justify-between font-body-sm text-body-sm text-on-surface-variant">
                        <span>IVA (16%)</span>
                        <span id="cart-iva">$0.00</span>
                    </div>
                    <div class="flex justify-between font-title-md text-title-md text-primary-fixed pt-1 border-t border-outline-variant">
                        <span>Total</span>
                        <span id="cart-total">$0.00</span>
                    </div>
                </div>
                <!-- Payment Methods -->
                <div class="mb-3">
                    <span class="font-label-caps text-[10px] text-on-surface-variant block mb-1">Método de Pago</span>
                    <div class="flex bg-surface-container-highest rounded-lg p-1 border border-outline-variant" id="payment-method-container">
                        <button data-metodo="Efectivo" class="payment-method-btn flex-1 py-1 bg-surface-container rounded shadow-sm flex flex-col items-center justify-center text-primary-fixed border border-primary-fixed/30 transition-colors">
                            <span class="material-symbols-outlined text-[16px] mb-0.5">payments</span>
                            <span class="font-label-caps text-[9px]">Efectivo</span>
                        </button>
                        <button data-metodo="Tarjeta" class="payment-method-btn flex-1 py-1 rounded flex flex-col items-center justify-center text-on-surface hover:text-primary-fixed transition-colors border-0 bg-transparent">
                            <span class="material-symbols-outlined text-[16px] mb-0.5">credit_card</span>
                            <span class="font-label-caps text-[9px]">Tarjeta</span>
                        </button>
                        <button data-metodo="Transferencia" class="payment-method-btn flex-1 py-1 rounded flex flex-col items-center justify-center text-on-surface hover:text-primary-fixed transition-colors border-0 bg-transparent">
                            <span class="material-symbols-outlined text-[16px] mb-0.5">account_balance</span>
                            <span class="font-label-caps text-[9px]">Transfer.</span>
                        </button>
                    </div>
                </div>
                <!-- Action Button -->
                <button id="btn-procesar-pago" class="w-full py-2.5 bg-primary-container text-on-primary-container rounded-lg font-title-md text-title-md hover:bg-surface-tint transition-all active:scale-[0.98] neon-glow flex justify-center items-center gap-2 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-[20px]">point_of_sale</span>
                    Procesar Pago
                </button>
            </div>
        </aside>
    </div>

    <!-- Modal Nuevo Producto -->
    <div id="modal-nuevo-producto" class="fixed inset-0 bg-[#000000]/80 z-50 hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-surface-container rounded-2xl w-full max-w-md border border-outline-variant shadow-2xl p-6 flex flex-col gap-6 scale-95 transition-transform duration-200">
            <div class="flex justify-between items-center">
                <h2 class="font-title-lg text-title-lg text-on-surface">Registrar Nuevo Producto</h2>
                <button id="btn-close-modal" class="text-on-surface-variant hover:text-on-surface cursor-pointer bg-transparent border-0 p-1 flex items-center justify-center rounded-full hover:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <form id="form-nuevo-producto" class="flex flex-col gap-4">
                <div>
                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Nombre del Producto</label>
                    <input type="text" id="nuevo-nombre" required class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="Ej. Proteína Whey 2kg">
                </div>
                
                <div>
                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Categoría</label>
                    <select id="nuevo-categoria-select" class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed mb-2">
                        <!-- Llenado dinámicamente -->
                        <option value="nueva">Otra / Nueva categoría...</option>
                    </select>
                    <input type="text" id="nuevo-categoria-input" class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed hidden" placeholder="Escribe la nueva categoría">
                </div>
                
                <div class="flex gap-4">
                    <div class="flex-1">
                        <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Precio ($)</label>
                        <input type="number" step="0.01" min="0" id="nuevo-precio" required class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="0.00">
                    </div>
                    <div class="flex-1">
                        <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Stock Inicial</label>
                        <input type="number" min="0" id="nuevo-stock" required class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="0">
                    </div>
                </div>
                
                <div class="pt-2 flex justify-end gap-3 mt-4 border-t border-outline-variant">
                    <button type="button" id="btn-cancel-modal" class="px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest rounded-lg transition-colors cursor-pointer border-0 bg-transparent">Cancelar</button>
                    <button type="submit" id="btn-save-producto" class="px-6 py-2 bg-primary-fixed text-on-primary-fixed rounded-lg font-label-caps text-label-caps hover:bg-primary-fixed/90 transition-colors flex items-center gap-2 cursor-pointer shadow-md shadow-primary-fixed/20 border-0">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
    <!-- Modal Productos Inactivos -->
    <div id="modal-productos-inactivos" class="fixed inset-0 bg-[#000000]/80 z-50 hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-surface-container rounded-2xl w-full max-w-lg border border-outline-variant shadow-2xl p-6 flex flex-col gap-6 scale-95 transition-transform duration-200">
            <div class="flex justify-between items-center">
                <h2 class="font-title-lg text-title-lg text-on-surface">Productos Archivados</h2>
                <button id="btn-close-modal-inactivos" class="text-on-surface-variant hover:text-on-surface cursor-pointer bg-transparent border-0 p-1 flex items-center justify-center rounded-full hover:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div id="loading-inactivos" class="py-6 flex justify-center hidden">
                <span class="material-symbols-outlined animate-spin text-primary-fixed text-2xl">progress_activity</span>
            </div>

            <div id="lista-inactivos-container" class="max-h-96 overflow-y-auto space-y-2 pr-1 custom-scrollbar">
                <!-- Se cargan dinámicamente -->
            </div>
            
            <div class="pt-2 flex justify-end mt-2 border-t border-outline-variant">
                <button type="button" id="btn-cerrar-modal-inactivos" class="px-4 py-2 font-label-caps text-label-caps text-on-surface hover:bg-surface-container-highest rounded-lg transition-colors cursor-pointer border border-outline-variant bg-transparent">Cerrar</button>
            </div>
        </div>
    </div>

    <!-- Modal Reabastecer Producto -->
    <div id="modal-reabastecer-producto" class="fixed inset-0 bg-[#000000]/80 z-50 hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-surface-container rounded-2xl w-full max-w-md border border-outline-variant shadow-2xl p-6 flex flex-col gap-6 scale-95 transition-transform duration-200">
            <div class="flex justify-between items-center">
                <h2 id="title-modal-reabastecer" class="font-title-lg text-title-lg text-on-surface">Reabastecer Stock</h2>
                <button id="btn-close-modal-reabastecer" class="text-on-surface-variant hover:text-on-surface cursor-pointer bg-transparent border-0 p-1 flex items-center justify-center rounded-full hover:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <form id="form-reabastecer-producto" class="flex flex-col gap-4">
                <input type="hidden" id="reabastecer-codigo">
                
                <div>
                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Producto</label>
                    <input type="text" id="reabastecer-nombre" disabled class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-3 py-2 text-sm text-on-surface-variant opacity-80 cursor-not-allowed">
                </div>

                <div>
                    <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Tipo de Ajuste</label>
                    <select id="reabastecer-tipo" class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed">
                        <option value="reabastecer">➕ Agregar nuevo stock (Compra)</option>
                        <option value="ajuste">🔄 Establecer stock exacto (Inventario físico)</option>
                    </select>
                </div>
                
                <div class="flex gap-4">
                    <div class="flex-1">
                        <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Stock Actual</label>
                        <input type="text" id="reabastecer-stock-actual" disabled class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-3 py-2 text-sm text-on-surface-variant opacity-80 cursor-not-allowed">
                    </div>
                    <div class="flex-1">
                        <label id="label-reabastecer-cantidad" class="block text-xs font-label-caps text-on-surface-variant mb-1">Cantidad a Agregar</label>
                        <input type="number" min="1" id="reabastecer-cantidad" required class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="Ej. 10">
                    </div>
                </div>

                <div id="reabastecer-gasto-container" class="bg-surface-container-high p-4 rounded-lg border border-outline-variant mt-2 flex flex-col gap-3">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary-fixed text-[18px]">account_balance</span>
                        <span class="font-label-caps text-label-caps text-on-surface">Registrar Gasto</span>
                    </div>
                    <div>
                        <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Costo Total de Compra ($)</label>
                        <input type="number" step="0.01" min="0.01" id="reabastecer-costo" required class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="0.00">
                        <p class="text-[10px] text-on-surface-variant mt-1">Este egreso se registrará automáticamente en Finanzas.</p>
                    </div>
                    <div>
                        <label class="block text-xs font-label-caps text-on-surface-variant mb-1">Concepto del Gasto</label>
                        <input type="text" id="reabastecer-concepto" class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary-fixed" placeholder="Opcional. Ej. Compra de stock">
                    </div>
                </div>
                
                <div class="pt-2 flex justify-end gap-3 mt-2 border-t border-outline-variant">
                    <button type="button" id="btn-cancel-modal-reabastecer" class="px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest rounded-lg transition-colors cursor-pointer border-0 bg-transparent">Cancelar</button>
                    <button type="submit" id="btn-save-reabastecer" class="px-6 py-2 bg-primary-fixed text-on-primary-fixed rounded-lg font-label-caps text-label-caps hover:bg-primary-fixed/90 transition-colors flex items-center gap-2 cursor-pointer shadow-md shadow-primary-fixed/20 border-0">
                        <span class="material-symbols-outlined text-[18px]">inventory</span>
                        <span id="text-btn-reabastecer">Reabastecer</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const API_BASE_URL = 'https://script.google.com/macros/s/AKfycbz-5zbcyoNX5sSrVp39Ocj6NbTqIP7XSHLti5o2AfrOl5dcD_-6mf2ieLN2XkldklCNAQ/exec';
            const grid = document.getElementById('membresias-grid');
            const otrosGrid = document.getElementById('otros-grid');
            const loading = document.getElementById('loading-pos');
            const productosSearchBar = document.getElementById('productos-search-bar');
            const productosSearchInput = document.getElementById('productos-search-input') as HTMLInputElement;
            
            const cartItemsContainer = document.getElementById('cart-items-container');
            const cartItemCount = document.getElementById('cart-item-count');
            const cartSubtotal = document.getElementById('cart-subtotal');
            const cartIva = document.getElementById('cart-iva');
            const cartTotal = document.getElementById('cart-total');
            const btnProcesarPago = document.getElementById('btn-procesar-pago');
            
            const memberSearchInput = document.getElementById('member-search-input') as HTMLInputElement;
            const btnSearchMember = document.getElementById('btn-search-member');
            const selectedMemberInfo = document.getElementById('selected-member-info');
            const selectedMemberName = document.getElementById('selected-member-name');
            const selectedMemberIdDisplay = document.getElementById('selected-member-id-display');
            const btnClearMember = document.getElementById('btn-clear-member');
            
            // Papelera / Inactivos Elements
            const btnInactivos = document.getElementById('btn-productos-inactivos');
            const modalInactivos = document.getElementById('modal-productos-inactivos');
            const btnCloseModalInactivos = document.getElementById('btn-close-modal-inactivos');
            const btnCerrarModalInactivos = document.getElementById('btn-cerrar-modal-inactivos');
            const loadingInactivos = document.getElementById('loading-inactivos');
            const listaInactivosContainer = document.getElementById('lista-inactivos-container');
            
            // Reabastecer Elements
            const modalReabastecer = document.getElementById('modal-reabastecer-producto');
            const btnCloseModalReabastecer = document.getElementById('btn-close-modal-reabastecer');
            const btnCancelModalReabastecer = document.getElementById('btn-cancel-modal-reabastecer');
            const formReabastecer = document.getElementById('form-reabastecer-producto');
            const inputReabastecerCodigo = document.getElementById('reabastecer-codigo');
            const inputReabastecerNombre = document.getElementById('reabastecer-nombre');
            const inputReabastecerStockActual = document.getElementById('reabastecer-stock-actual');
            const inputReabastecerCantidad = document.getElementById('reabastecer-cantidad') as HTMLInputElement;
            const inputReabastecerCosto = document.getElementById('reabastecer-costo') as HTMLInputElement;
            const inputReabastecerConcepto = document.getElementById('reabastecer-concepto') as HTMLInputElement;
            const selectReabastecerTipo = document.getElementById('reabastecer-tipo') as HTMLSelectElement;
            const containerReabastecerGasto = document.getElementById('reabastecer-gasto-container') as HTMLDivElement;
            const labelReabastecerCantidad = document.getElementById('label-reabastecer-cantidad') as HTMLLabelElement;
            const titleModalReabastecer = document.getElementById('title-modal-reabastecer') as HTMLHeadingElement;
            const textBtnReabastecer = document.getElementById('text-btn-reabastecer') as HTMLSpanElement;

            let catalogoProductos = [];
            let cart = [];
            let selectedMetodoPago = 'Efectivo';
            let selectedMember = null;

            // Setup tabs
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.tab-btn').forEach(b => {
                        b.className = "tab-btn font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface pb-2 px-2 transition-colors border-b-2 border-transparent";
                    });
                    const target = e.currentTarget as HTMLElement;
                    target.className = "tab-btn font-label-caps text-label-caps text-primary-fixed border-b-2 border-primary-fixed pb-2 px-2";

                    if(target.dataset.tab === 'membresias') {
                        grid.classList.remove('hidden');
                        otrosGrid.classList.add('hidden');
                        productosSearchBar.classList.add('hidden');
                        productosSearchInput.value = '';
                    } else {
                        grid.classList.add('hidden');
                        otrosGrid.classList.remove('hidden');
                        productosSearchBar.classList.remove('hidden');
                        renderProductos(''); // Mostrar todos al cambiar a pestaña Productos
                    }
                });
            });

            // Renderiza el grid de productos aplicando un filtro de texto (nombre o categoría)
            const renderProductos = (filtro: string) => {
                otrosGrid.innerHTML = '';
                const texto = filtro.toLowerCase();
                const productosFiltrados = texto
                    ? catalogoProductos.filter(p =>
                        p.nombre.toLowerCase().includes(texto) ||
                        p.categoria.toLowerCase().includes(texto)
                    )
                    : catalogoProductos;

                if (productosFiltrados.length === 0) {
                    otrosGrid.innerHTML = `<p class="text-on-surface-variant col-span-4 text-center py-8">
                        ${texto ? `No se encontraron productos para "<strong>${filtro}</strong>"` : 'No hay productos disponibles.'}
                    </p>`;
                    return;
                }

                productosFiltrados.forEach(producto => {
                    const agotado = producto.stock <= 0;
                    // Cantidad de este producto que ya está en el carrito
                    const enCarrito = cart.find(i => i.codigo === producto.codigo)?.cantidad || 0;
                    const stockAgotadoPorCarrito = enCarrito >= producto.stock;
                    const deshabilitado = agotado || stockAgotadoPorCarrito;

                    const card = document.createElement('div');
                    card.className = `bg-surface-container rounded-xl border p-4 flex flex-col transition-colors group ${
                        deshabilitado
                            ? 'border-error/20 opacity-60 cursor-not-allowed'
                            : 'border-outline-variant hover:border-primary-fixed/50'
                    }`;

                    const chipStock = agotado
                        ? `<div class="absolute top-2 right-2 bg-error/10 px-2 py-1 rounded text-[10px] font-label-caps text-error border border-error/30">Agotado</div>`
                        : stockAgotadoPorCarrito
                        ? `<div class="absolute top-2 right-2 bg-error/10 px-2 py-1 rounded text-[10px] font-label-caps text-error border border-error/30">Máx. en carrito</div>`
                        : `<div class="absolute top-2 right-2 bg-surface-container-low px-2 py-1 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant">Stock: ${producto.stock}</div>`;

                    const btnAdd = deshabilitado
                        ? `<button class="add-to-cart-btn w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant cursor-not-allowed border-0 opacity-40" disabled data-codigo="${producto.codigo}">
                               <span class="material-symbols-outlined text-[18px]">block</span>
                           </button>`
                        : `<button class="add-to-cart-btn w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors cursor-pointer border-0" data-codigo="${producto.codigo}">
                               <span class="material-symbols-outlined text-[18px]">add</span>
                           </button>`;

                    card.innerHTML = `
                        <div class="h-32 bg-surface-container-highest rounded-lg mb-4 overflow-hidden relative flex items-center justify-center">
                            <span class="material-symbols-outlined text-outline-variant text-3xl">image</span>
                            ${chipStock}
                            <button class="btn-reabastecer-producto absolute top-2 left-2 w-7 h-7 bg-primary-fixed/90 text-on-primary-fixed rounded flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer border border-primary-fixed/50 shadow-sm shadow-black/50 hover:bg-primary-fixed backdrop-blur" data-codigo="${producto.codigo}" data-nombre="${producto.nombre}" data-stock="${producto.stock}" title="Reabastecer stock">
                                <span class="material-symbols-outlined text-[14px]">inventory</span>
                            </button>
                            <button class="btn-delete-producto absolute top-2 left-10 w-7 h-7 bg-error/90 text-on-error rounded flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer border border-error/50 shadow-sm shadow-black/50 hover:bg-error backdrop-blur" data-codigo="${producto.codigo}" title="Eliminar producto">
                                <span class="material-symbols-outlined text-[14px]">delete</span>
                            </button>
                        </div>
                        <h3 class="font-data-table text-data-table text-on-surface mb-1 truncate">${producto.nombre}</h3>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex-1 text-xs">${producto.categoria}</p>
                        <div class="flex justify-between items-center mt-auto">
                            <span class="font-headline-md text-headline-md ${deshabilitado ? 'text-on-surface-variant' : 'text-primary-fixed'}">$${producto.precio}</span>
                            ${btnAdd}
                        </div>
                    `;

                    if (!deshabilitado) {
                        card.querySelector('.add-to-cart-btn').addEventListener('click', (e) => {
                            e.stopPropagation();
                            addToCart(producto);
                        });
                    }
                    
                    card.querySelector('.btn-delete-producto').addEventListener('click', (e) => {
                        e.stopPropagation();
                        eliminarProductoReq(producto);
                    });
                    
                    card.querySelector('.btn-reabastecer-producto').addEventListener('click', (e) => {
                        e.stopPropagation();
                        const btn = e.currentTarget;
                        abrirModalReabastecer(btn.dataset.codigo, btn.dataset.nombre, btn.dataset.stock);
                    });

                    otrosGrid.appendChild(card);
                });
            };

            // Cart Totals and Render functions
            const updateCartTotals = () => {
                let total = 0;
                let count = 0;
                cart.forEach(item => {
                    total += item.precio * item.cantidad;
                    count += item.cantidad;
                });

                const subtotal = total / 1.16;
                const iva = total - subtotal;

                cartItemCount.textContent = `${count} ${count === 1 ? 'Item' : 'Items'}`;
                cartSubtotal.textContent = `$${subtotal.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                cartIva.textContent = `$${iva.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                cartTotal.textContent = `$${total.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

                if (cart.length === 0) {
                    btnProcesarPago.setAttribute('disabled', 'true');
                } else {
                    btnProcesarPago.removeAttribute('disabled');
                }
            };

            const renderCart = () => {
                if (cart.length === 0) {
                    cartItemsContainer.innerHTML = `
                        <div class="text-center text-on-surface-variant py-8 font-body-md">
                            <span class="material-symbols-outlined text-4xl block mb-2 text-outline-variant">shopping_cart</span>
                            El carrito está vacío
                        </div>
                    `;
                    updateCartTotals();
                    return;
                }

                cartItemsContainer.innerHTML = '';
                cart.forEach(item => {
                    const itemDiv = document.createElement('div');
                    itemDiv.className = "flex gap-3 items-center bg-surface-container-highest p-2.5 rounded-lg border border-outline-variant/50";
                    itemDiv.innerHTML = `
                        <div class="w-10 h-10 bg-surface-container rounded flex items-center justify-center text-on-surface-variant overflow-hidden flex-shrink-0">
                            ${item.imagen ? `<img src="${item.imagen}" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />` : ''}
                            <span class="material-symbols-outlined text-[18px] ${item.imagen ? 'hidden' : ''}">image</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="font-body-md text-sm text-on-surface truncate leading-tight">${item.nombre}</h4>
                            <div class="flex items-center gap-2 mt-1">
                                <button class="btn-qty-minus w-5 h-5 bg-surface-container rounded flex items-center justify-center text-on-surface hover:text-primary-fixed cursor-pointer border-0" data-codigo="${item.codigo}">
                                    <span class="material-symbols-outlined text-[14px]">remove</span>
                                </button>
                                <span class="font-label-caps text-label-caps text-xs">${item.cantidad}</span>
                                <button class="btn-qty-plus w-5 h-5 bg-surface-container rounded flex items-center justify-center transition-colors border-0 ${item.cantidad >= item.stock ? 'text-on-surface-variant opacity-40 cursor-not-allowed' : 'text-on-surface hover:text-primary-fixed cursor-pointer'}" data-codigo="${item.codigo}" ${item.cantidad >= item.stock ? 'disabled' : ''}>
                                    <span class="material-symbols-outlined text-[14px]">add</span>
                                </button>
                            </div>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <div class="font-data-table text-data-table text-primary-fixed">$${(item.precio * item.cantidad).toFixed(2)}</div>
                            <button class="btn-remove-item text-on-surface-variant hover:text-error transition-colors mt-1 cursor-pointer bg-transparent border-0 p-0" data-codigo="${item.codigo}">
                                <span class="material-symbols-outlined text-[16px]">delete</span>
                            </button>
                        </div>
                    `;
                    cartItemsContainer.appendChild(itemDiv);
                });

                // Attach events
                cartItemsContainer.querySelectorAll('.btn-qty-minus').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const target = e.currentTarget as HTMLElement;
                        const codigo = target.dataset.codigo;
                        const idx = cart.findIndex(i => String(i.codigo) === String(codigo));
                        if (idx > -1) {
                            if (cart[idx].cantidad > 1) {
                                cart[idx].cantidad--;
                            } else {
                                cart.splice(idx, 1);
                            }
                            renderCart();
                            renderProductos(productosSearchInput.value.trim());
                        }
                    });
                });

                cartItemsContainer.querySelectorAll('.btn-qty-plus').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const target = e.currentTarget as HTMLElement;
                        const codigo = target.dataset.codigo;
                        const idx = cart.findIndex(i => String(i.codigo) === String(codigo));
                        if (idx > -1) {
                            const stockMax = cart[idx].stock ?? Infinity;
                            if (cart[idx].cantidad < stockMax) {
                                cart[idx].cantidad++;
                                renderCart();
                                renderProductos(productosSearchInput.value.trim());
                            }
                        }
                    });
                });

                cartItemsContainer.querySelectorAll('.btn-remove-item').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const target = e.currentTarget as HTMLElement;
                        const codigo = target.dataset.codigo;
                        const idx = cart.findIndex(i => String(i.codigo) === String(codigo));
                        if (idx > -1) {
                            cart.splice(idx, 1);
                            renderCart();
                            renderProductos(productosSearchInput.value.trim());
                        }
                    });
                });

                updateCartTotals();
            };

            const addToCart = (producto) => {
                const existing = cart.find(i => String(i.codigo) === String(producto.codigo));
                if (existing) {
                    // Validar que no supere el stock disponible
                    const stockMax = producto.stock ?? Infinity;
                    if (existing.cantidad < stockMax) {
                        existing.cantidad++;
                    }
                } else {
                    cart.push({ ...producto, cantidad: 1 });
                }
                renderCart();
                // Re-renderizar tarjetas para actualizar el estado del botón si se llegó al límite
                renderProductos(productosSearchInput.value.trim());
            };

            // Función para eliminar
            const eliminarProductoReq = async (producto) => {
                if(!confirm(`¿Estás seguro de que deseas eliminar permanentemente "${producto.nombre}" (Código: ${producto.codigo})?`)) return;
                
                try {
                    const cardBtn = document.querySelector(`button.btn-delete-producto[data-codigo="${producto.codigo}"]`);
                    if(cardBtn) cardBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[14px]">progress_activity</span>';
                    
                    const payload = {
                        action: 'eliminarProducto',
                        codigo: producto.codigo
                    };
                    const res = await fetch(API_BASE_URL, {
                        method: 'POST',
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    
                    if(data.exito) {
                        // Eliminar del carrito si estaba agregado
                        cart = cart.filter(i => String(i.codigo) !== String(producto.codigo));
                        renderCart();
                        // Recargar catálogo
                        cargarCatalogos(true);
                    } else {
                        alert('Error al eliminar: ' + data.mensaje);
                        if(cardBtn) cardBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">delete</span>';
                    }
                } catch(err) {
                    alert('Error de conexión.');
                }
            };

            const cargarCatalogos = async (soloProductos = false) => {
                if (!soloProductos) {
                    grid.classList.add('hidden');
                } else {
                    otrosGrid.innerHTML = '<p class="text-on-surface-variant col-span-4 text-center py-8"><span class="material-symbols-outlined animate-spin text-primary-fixed text-2xl inline-block align-middle mr-2">progress_activity</span>Actualizando productos...</p>';
                }
                loading.classList.remove('hidden');

                try {
                    // Fetch memberships (only if not soloProductos)
                    if (!soloProductos) {
                        const resMembresias = await fetch(`${API_BASE_URL}?action=catalogoMembresias`);
                        const dataMembresias = await resMembresias.json();

                        if (dataMembresias.exito) {
                            grid.innerHTML = '';
                            dataMembresias.datos.forEach(membresia => {
                                const card = document.createElement('div');
                                card.className = "bg-surface-container rounded-xl border border-outline-variant p-4 flex flex-col hover:border-primary-fixed/50 transition-colors group";
                                
                                card.innerHTML = `
                                    <div class="h-32 bg-surface-container-highest rounded-lg mb-4 flex items-center justify-center relative overflow-hidden">
                                        <span class="material-symbols-outlined text-[48px] text-primary-fixed/30 group-hover:text-primary-fixed/70 transition-colors" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                                        <div class="absolute top-2 right-2 bg-surface-container-low px-2 py-1 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant">
                                            SOLO VISTA
                                        </div>
                                    </div>
                                    <h3 class="font-data-table text-data-table text-on-surface mb-1">${membresia.nombre}</h3>
                                    <p class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex-1">Vigencia: ${membresia.duracion} días</p>
                                    <div class="flex justify-between items-center mt-auto">
                                        <span class="font-headline-md text-headline-md text-primary-fixed">$${membresia.precio}</span>
                                        <span class="text-on-surface-variant text-xs font-label-caps">Inscribir en Menú</span>
                                    </div>
                                `;
                                grid.appendChild(card);
                            });
                        }
                    }

                    // Fetch products
                    const resProductos = await fetch(`${API_BASE_URL}?action=catalogoProductos`);
                    const dataProductos = await resProductos.json();

                    if (dataProductos.exito) {
                        catalogoProductos = dataProductos.datos;
                        renderProductos(productosSearchInput.value.trim()); // Render con filtro actual
                    } else {
                        otrosGrid.innerHTML = `<p class="text-error col-span-4">${dataProductos.mensaje || 'Error cargando catálogo de productos.'}</p>`;
                    }
                } catch (err) {
                    console.error("Error", err);
                    if(!soloProductos) grid.innerHTML = '<p class="text-error col-span-4">Error conectando con el servidor.</p>';
                    otrosGrid.innerHTML = '<p class="text-error col-span-4">Error conectando con el servidor.</p>';
                } finally {
                    loading.classList.add('hidden');
                    if (!soloProductos) grid.classList.remove('hidden');
                }
            };

            // Llamada inicial
            cargarCatalogos();

            // Modal logic
            const modalNuevo = document.getElementById('modal-nuevo-producto');
            const btnNuevo = document.getElementById('btn-nuevo-producto');
            const btnCloseModal = document.getElementById('btn-close-modal');
            const btnCancelModal = document.getElementById('btn-cancel-modal');
            const formNuevo = document.getElementById('form-nuevo-producto') as HTMLFormElement;
            const selectCategoria = document.getElementById('nuevo-categoria-select') as HTMLSelectElement;
            const inputCategoria = document.getElementById('nuevo-categoria-input') as HTMLInputElement;
            const btnSaveProducto = document.getElementById('btn-save-producto') as HTMLButtonElement;
            
            btnNuevo.addEventListener('click', () => {
                const categorias = [...new Set(catalogoProductos.map(p => p.categoria))].filter(Boolean).sort();
                selectCategoria.innerHTML = '';
                categorias.forEach(cat => {
                    const opt = document.createElement('option');
                    opt.value = cat;
                    opt.textContent = cat;
                    selectCategoria.appendChild(opt);
                });
                const optNueva = document.createElement('option');
                optNueva.value = 'nueva';
                optNueva.textContent = 'Otra / Nueva categoría...';
                selectCategoria.appendChild(optNueva);
                
                if(categorias.length === 0) {
                    selectCategoria.value = 'nueva';
                }
                
                if(selectCategoria.value === 'nueva') {
                    inputCategoria.classList.remove('hidden');
                    inputCategoria.setAttribute('required', 'true');
                } else {
                    inputCategoria.classList.add('hidden');
                    inputCategoria.removeAttribute('required');
                }
                
                modalNuevo.classList.remove('hidden');
                setTimeout(() => {
                    modalNuevo.firstElementChild.classList.remove('scale-95');
                    modalNuevo.firstElementChild.classList.add('scale-100');
                }, 10);
            });
            
            const cerrarModal = () => {
                modalNuevo.firstElementChild.classList.remove('scale-100');
                modalNuevo.firstElementChild.classList.add('scale-95');
                setTimeout(() => {
                    modalNuevo.classList.add('hidden');
                    formNuevo.reset();
                    inputCategoria.classList.add('hidden');
                    inputCategoria.removeAttribute('required');
                }, 200);
            };
            
            btnCloseModal.addEventListener('click', cerrarModal);
            btnCancelModal.addEventListener('click', cerrarModal);
            
            selectCategoria.addEventListener('change', () => {
                if (selectCategoria.value === 'nueva') {
                    inputCategoria.classList.remove('hidden');
                    inputCategoria.setAttribute('required', 'true');
                    inputCategoria.focus();
                } else {
                    inputCategoria.classList.add('hidden');
                    inputCategoria.removeAttribute('required');
                }
            });
            
            formNuevo.addEventListener('submit', async (e) => {
                e.preventDefault();
                const nombre = (document.getElementById('nuevo-nombre') as HTMLInputElement).value;
                const categoria = selectCategoria.value === 'nueva' ? inputCategoria.value.trim() : selectCategoria.value;
                const precio = (document.getElementById('nuevo-precio') as HTMLInputElement).value;
                const stock = (document.getElementById('nuevo-stock') as HTMLInputElement).value;
                
                btnSaveProducto.disabled = true;
                btnSaveProducto.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">progress_activity</span> Guardando...';
                
                try {
                    const payload = {
                        action: 'registrarProducto',
                        nombre,
                        categoria: categoria || 'Sin categoría',
                        precio: parseFloat(precio),
                        stock: parseInt(stock, 10)
                    };
                    const res = await fetch(API_BASE_URL, {
                        method: 'POST',
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    
                    if (data.exito) {
                        cerrarModal();
                        cargarCatalogos(true); // Recargar solo productos
                    } else {
                        alert('Error al registrar: ' + data.mensaje);
                    }
                } catch(err) {
                    alert('Error de conexión.');
                } finally {
                    btnSaveProducto.disabled = false;
                    btnSaveProducto.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Guardar';
                }
            });

            // Setup payment methods
            const paymentMethodContainer = document.getElementById('payment-method-container');
            const paymentBtns = paymentMethodContainer.querySelectorAll('.payment-method-btn');
            paymentBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    paymentBtns.forEach(b => {
                        b.className = "payment-method-btn flex-1 py-1 rounded flex flex-col items-center justify-center text-on-surface hover:text-primary-fixed transition-colors border-0 bg-transparent";
                    });
                    const targetBtn = e.currentTarget as HTMLElement;
                    targetBtn.className = "payment-method-btn flex-1 py-1 bg-surface-container rounded shadow-sm flex flex-col items-center justify-center text-primary-fixed border border-primary-fixed/30 transition-colors";
                    selectedMetodoPago = targetBtn.getAttribute('data-metodo');
                });
            });

            // Member lookup
            btnSearchMember.addEventListener('click', async () => {
                const id = memberSearchInput.value.trim();
                if (!id) return;

                btnSearchMember.setAttribute('disabled', 'true');
                btnSearchMember.innerHTML = '<span class="material-symbols-outlined text-[16px] animate-spin">progress_activity</span>';

                try {
                    const res = await fetch(`${API_BASE_URL}?action=datosRenovacionMiembro&idMiembro=${id}`);
                    const data = await res.json();
                    if (data.exito && data.datos && data.datos.miembro) {
                        selectedMember = {
                            id: id,
                            nombre: data.datos.miembro.nombre
                        };
                        selectedMemberName.textContent = selectedMember.nombre;
                        selectedMemberIdDisplay.textContent = `Socio #${selectedMember.id}`;
                        selectedMemberInfo.classList.remove('hidden');
                        memberSearchInput.value = '';
                    } else {
                        alert('Socio no encontrado.');
                        selectedMember = null;
                        selectedMemberInfo.classList.add('hidden');
                    }
                } catch (e) {
                    console.error(e);
                    alert('Error al buscar socio.');
                } finally {
                    btnSearchMember.removeAttribute('disabled');
                    btnSearchMember.innerHTML = '<span class="material-symbols-outlined text-[16px]">search</span>';
                }
            });

            memberSearchInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    btnSearchMember.click();
                }
            });

            btnClearMember.addEventListener('click', () => {
                selectedMember = null;
                selectedMemberInfo.classList.add('hidden');
            });

            // Checkout / Procesar Pago
            btnProcesarPago.addEventListener('click', async () => {
                if (cart.length === 0) return;

                btnProcesarPago.setAttribute('disabled', 'true');
                btnProcesarPago.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px]">progress_activity</span> Procesando...';

                try {
                    const payload = {
                        action: 'registrarVentaPOS',
                        tipoCliente: selectedMember ? 'Miembro' : 'Público General',
                        miembro: selectedMember ? selectedMember.id : '',
                        nombre: selectedMember ? selectedMember.nombre : 'Público General',
                        metodoPago: selectedMetodoPago,
                        totalCobrado: cart.reduce((acc, item) => acc + (item.precio * item.cantidad), 0),
                        productos: cart.map(item => ({
                            codigo: item.codigo,
                            nombre: item.nombre,
                            categoria: item.categoria,
                            cantidad: item.cantidad,
                            precioUnitario: item.precio,
                            subtotal: item.precio * item.cantidad
                        }))
                    };

                    const res = await fetch(API_BASE_URL, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'text/plain;charset=utf-8'
                        },
                        body: JSON.stringify(payload)
                    });

                    const data = await res.json();
                    if (data.exito) {
                        alert('¡Venta registrada con éxito!');
                        cart = [];
                        selectedMember = null;
                        selectedMemberInfo.classList.add('hidden');
                        renderCart();
                        
                        // Reload products to get latest stock
                        window.location.reload();
                    } else {
                        alert('Error al registrar venta: ' + data.mensaje);
                    }
                } catch (e) {
                    console.error(e);
                    alert('Error de conexión con el servidor.');
                } finally {
                    btnProcesarPago.removeAttribute('disabled');
                    btnProcesarPago.innerHTML = '<span class="material-symbols-outlined">point_of_sale</span> Procesar Pago';
                }
            });

            // Modal inactivos logic
            btnInactivos.addEventListener('click', async () => {
                modalInactivos.classList.remove('hidden');
                setTimeout(() => {
                    modalInactivos.firstElementChild.classList.remove('scale-95');
                    modalInactivos.firstElementChild.classList.add('scale-100');
                }, 10);
                await cargarProductosInactivos();
            });

            const cerrarModalInactivos = () => {
                modalInactivos.firstElementChild.classList.remove('scale-100');
                modalInactivos.firstElementChild.classList.add('scale-95');
                setTimeout(() => {
                    modalInactivos.classList.add('hidden');
                    listaInactivosContainer.innerHTML = '';
                }, 200);
            };

            btnCloseModalInactivos.addEventListener('click', cerrarModalInactivos);
            btnCerrarModalInactivos.addEventListener('click', cerrarModalInactivos);

            const cargarProductosInactivos = async () => {
                loadingInactivos.classList.remove('hidden');
                listaInactivosContainer.innerHTML = '';
                try {
                    const res = await fetch(`${API_BASE_URL}?action=catalogoProductosInactivos`);
                    const data = await res.json();
                    if (data.exito) {
                        if (data.datos.length === 0) {
                            listaInactivosContainer.innerHTML = '<p class="text-on-surface-variant text-center py-4">No hay productos archivados.</p>';
                        } else {
                            data.datos.forEach(prod => {
                                const row = document.createElement('div');
                                row.className = "flex items-center justify-between bg-surface-container-highest p-3 rounded-lg border border-outline-variant gap-4";
                                row.innerHTML = `
                                    <div class="flex flex-col min-w-0 flex-1">
                                        <span class="font-body-md text-on-surface font-semibold truncate">${prod.nombre}</span>
                                        <span class="text-xs text-on-surface-variant truncate">${prod.categoria} | $${prod.precio} | Stock: ${prod.stock}</span>
                                    </div>
                                    <button class="btn-reactivar-prod font-label-caps text-label-caps bg-primary-fixed text-on-primary-fixed hover:bg-primary-fixed/90 px-3 py-1.5 rounded transition-colors flex items-center gap-1 cursor-pointer border-0 shrink-0" data-codigo="${prod.codigo}">
                                        <span class="material-symbols-outlined text-[16px]">restore</span>
                                        Reactivar
                                    </button>
                                `;
                                
                                row.querySelector('.btn-reactivar-prod').addEventListener('click', async (e) => {
                                    const btn = e.currentTarget as HTMLButtonElement;
                                    btn.disabled = true;
                                    btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px]">progress_activity</span>';
                                    try {
                                        const reactRes = await fetch(API_BASE_URL, {
                                            method: 'POST',
                                            body: JSON.stringify({
                                                action: 'reactivarProducto',
                                                codigo: prod.codigo
                                            })
                                        });
                                        const reactData = await reactRes.json();
                                        if (reactData.exito) {
                                            row.remove();
                                            if (listaInactivosContainer.children.length === 0) {
                                                listaInactivosContainer.innerHTML = '<p class="text-on-surface-variant text-center py-4">No hay productos archivados.</p>';
                                            }
                                            // Recargar catálogo de productos activos
                                            await cargarCatalogos(true);
                                        } else {
                                            alert('Error: ' + reactData.mensaje);
                                            btn.disabled = false;
                                            btn.innerHTML = '<span class="material-symbols-outlined text-[16px]">restore</span> Reactivar';
                                        }
                                    } catch (err) {
                                        alert('Error al reactivar.');
                                        btn.disabled = false;
                                        btn.innerHTML = '<span class="material-symbols-outlined text-[16px]">restore</span> Reactivar';
                                    }
                                });
                                
                                listaInactivosContainer.appendChild(row);
                            });
                        }
                    } else {
                        listaInactivosContainer.innerHTML = `<p class="text-error text-center py-4">${data.mensaje || 'Error al cargar inactivos.'}</p>`;
                    }
                } catch(err) {
                    listaInactivosContainer.innerHTML = '<p class="text-error text-center py-4">Error de conexión al cargar papelera.</p>';
                } finally {
                    loadingInactivos.classList.add('hidden');
                }
            };

            // Modal Reabastecer logic
            window.abrirModalReabastecer = (codigo, nombre, stock) => {
                inputReabastecerCodigo.value = codigo;
                inputReabastecerNombre.value = nombre;
                inputReabastecerStockActual.value = stock;
                inputReabastecerCantidad.value = '';
                inputReabastecerCosto.value = '';
                inputReabastecerConcepto.value = '';
                
                // Reset a tipo reabastecer por defecto
                selectReabastecerTipo.value = 'reabastecer';
                titleModalReabastecer.textContent = "Reabastecer Stock";
                labelReabastecerCantidad.textContent = "Cantidad a Agregar";
                inputReabastecerCantidad.min = "1";
                inputReabastecerCantidad.placeholder = "Ej. 10";
                containerReabastecerGasto.classList.remove('hidden');
                inputReabastecerCosto.setAttribute('required', 'true');
                textBtnReabastecer.textContent = "Reabastecer";
                
                modalReabastecer.classList.remove('hidden');
                setTimeout(() => {
                    modalReabastecer.firstElementChild.classList.remove('scale-95');
                    modalReabastecer.firstElementChild.classList.add('scale-100');
                }, 10);
            };

            selectReabastecerTipo.addEventListener('change', () => {
                const tipo = selectReabastecerTipo.value;
                if (tipo === 'reabastecer') {
                    titleModalReabastecer.textContent = "Reabastecer Stock";
                    labelReabastecerCantidad.textContent = "Cantidad a Agregar";
                    inputReabastecerCantidad.min = "1";
                    inputReabastecerCantidad.placeholder = "Ej. 10";
                    containerReabastecerGasto.classList.remove('hidden');
                    inputReabastecerCosto.setAttribute('required', 'true');
                    textBtnReabastecer.textContent = "Reabastecer";
                } else {
                    titleModalReabastecer.textContent = "Ajustar Stock";
                    labelReabastecerCantidad.textContent = "Nuevo Stock Exacto";
                    inputReabastecerCantidad.min = "0";
                    inputReabastecerCantidad.placeholder = "Ej. 5";
                    containerReabastecerGasto.classList.add('hidden');
                    inputReabastecerCosto.removeAttribute('required');
                    textBtnReabastecer.textContent = "Ajustar Stock";
                }
            });

            const cerrarModalReabastecer = () => {
                modalReabastecer.firstElementChild.classList.remove('scale-100');
                modalReabastecer.firstElementChild.classList.add('scale-95');
                setTimeout(() => {
                    modalReabastecer.classList.add('hidden');
                }, 200);
            };

            btnCloseModalReabastecer.addEventListener('click', cerrarModalReabastecer);
            btnCancelModalReabastecer.addEventListener('click', cerrarModalReabastecer);
            modalReabastecer.addEventListener('click', (e) => {
                if(e.target === modalReabastecer) cerrarModalReabastecer();
            });

            formReabastecer.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const btnSubmit = document.getElementById('btn-save-reabastecer');
                const originalText = btnSubmit.innerHTML;
                
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = `<span class="material-symbols-outlined animate-spin">progress_activity</span> Guardando...`;

                const datos = {
                    action: 'reabastecerProducto',
                    codigo: inputReabastecerCodigo.value,
                    tipo: selectReabastecerTipo.value,
                    cantidad: inputReabastecerCantidad.value,
                    costo: selectReabastecerTipo.value === 'reabastecer' ? inputReabastecerCosto.value : '0',
                    concepto: selectReabastecerTipo.value === 'reabastecer' ? inputReabastecerConcepto.value : ''
                };

                try {
                    const res = await fetch(API_BASE_URL, {
                        method: 'POST',
                        body: JSON.stringify(datos)
                    });
                    const resData = await res.json();
                    
                    if(resData.exito) {
                        alert(resData.mensaje);
                        cerrarModalReabastecer();
                        await cargarCatalogos(true); // Recargar catálogo para actualizar UI
                    } else {
                        alert('Error: ' + resData.mensaje);
                    }
                } catch(err) {
                    alert('Error de red al actualizar el stock del producto.');
                } finally {
                    btnSubmit.disabled = false;
                    btnSubmit.innerHTML = originalText;
                }
            });

            // Initialize cart state
            updateCartTotals();
        });
    </script>
</DashboardLayout>
