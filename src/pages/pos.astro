---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Punto de Venta">
    <div class="flex h-[calc(100vh-64px)] -m-6"> 
        <!-- Main Content Canvas (Reports & POS Products) -->
        <div class="flex-1 overflow-y-auto p-container-margin flex flex-col gap-stack-xl">
            <!-- POS Products Section -->
            <section class="flex-1 flex flex-col pb-stack-lg">
                <div class="flex justify-between items-center border-b border-outline-variant pb-2 mb-stack-md">
                    <h2 class="font-headline-md text-headline-md text-on-background">Punto de Venta</h2>
                    <div class="flex items-center gap-4">
                        <div class="flex gap-4" id="pos-tabs">
                            <button data-tab="membresias" class="tab-btn font-label-caps text-label-caps text-primary-fixed border-b-2 border-primary-fixed pb-2 px-2">Membresías</button>
                            <button data-tab="otros" class="tab-btn font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface pb-2 px-2 transition-colors border-b-2 border-transparent">Productos</button>
                        </div>
                        <div class="ml-4 pl-4 border-l border-outline-variant">
                            <button class="font-label-caps text-label-caps bg-surface-container-highest text-primary-fixed border border-primary-fixed/30 rounded-lg px-4 py-2 hover:bg-surface-variant transition-colors flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">add</span>
                                Nuevo Producto
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Loader -->
                <div id="loading-pos" class="py-12 flex justify-center hidden">
                    <span class="material-symbols-outlined animate-spin text-primary-fixed text-4xl">progress_activity</span>
                </div>

                <!-- Dynamic Grid for Membresias (Solo Vista) -->
                <div id="membresias-grid" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter overflow-y-auto">
                    <!-- Loaded dynamically -->
                </div>

                <!-- Static Grid for Productos (Solo para visualización extra en mockup) -->
                <div id="otros-grid" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter overflow-y-auto hidden">
                    <div class="bg-surface-container rounded-xl border border-outline-variant p-4 flex flex-col hover:border-primary-fixed/50 transition-colors group">
                        <div class="h-32 bg-surface-container-highest rounded-lg mb-4 overflow-hidden relative">
                            <div class="w-full h-full bg-[#1A1A1A] flex items-center justify-center">
                                <span class="material-symbols-outlined text-outline-variant text-3xl">image</span>
                            </div>
                        </div>
                        <h3 class="font-data-table text-data-table text-on-surface mb-1">Whey Protein Isolate</h3>
                        <p class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex-1">Sabor Vainilla - 2kg</p>
                        <div class="flex justify-between items-center mt-auto">
                            <span class="font-headline-md text-headline-md text-primary-fixed">$1,200</span>
                            <button class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors">
                                <span class="material-symbols-outlined text-[18px]">add</span>
                            </button>
                        </div>
                    </div>
                </div>

            </section>
        </div>
        
        <!-- Right Sidebar: Shopping Cart / Checkout -->
        <aside class="w-96 min-w-[384px] border-l border-outline-variant bg-surface-container flex flex-col z-10 shadow-[-10px_0_30px_rgba(0,0,0,0.5)]">
            <!-- Cart Header -->
            <div class="p-container-margin border-b border-outline-variant flex justify-between items-center">
                <h2 class="font-headline-md text-headline-md text-on-background">Carrito Actual</h2>
                <span class="bg-primary-container/20 text-primary-fixed px-2 py-1 rounded font-label-caps text-label-caps">1 Item</span>
            </div>
            <!-- Cart Items List -->
            <div class="flex-1 overflow-y-auto p-container-margin space-y-4">
                <!-- Cart Item -->
                <div class="flex gap-4 items-center bg-surface-container-highest p-3 rounded-lg border border-outline-variant/50">
                    <div class="w-12 h-12 bg-surface-container rounded flex items-center justify-center text-on-surface-variant">
                        <span class="material-symbols-outlined text-[20px]">image</span>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-data-table text-data-table text-on-surface">Whey Protein Isolate</h4>
                        <div class="flex items-center gap-2 mt-1">
                            <button class="w-5 h-5 bg-surface-container rounded flex items-center justify-center text-on-surface hover:text-primary-fixed cursor-pointer"><span class="material-symbols-outlined text-[14px]">remove</span></button>
                            <span class="font-label-caps text-label-caps">1</span>
                            <button class="w-5 h-5 bg-surface-container rounded flex items-center justify-center text-on-surface hover:text-primary-fixed cursor-pointer"><span class="material-symbols-outlined text-[14px]">add</span></button>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="font-data-table text-data-table text-primary-fixed">$1,200</div>
                        <button class="text-on-surface-variant hover:text-error transition-colors mt-1 cursor-pointer">
                            <span class="material-symbols-outlined text-[16px]">delete</span>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Checkout Section -->
            <div class="p-container-margin border-t border-outline-variant bg-surface-container-low">
                <!-- Totals -->
                <div class="space-y-2 mb-stack-md">
                    <div class="flex justify-between font-body-md text-body-md text-on-surface-variant">
                        <span>Subtotal</span>
                        <span>$1,034.48</span>
                    </div>
                    <div class="flex justify-between font-body-md text-body-md text-on-surface-variant">
                        <span>IVA (16%)</span>
                        <span>$165.52</span>
                    </div>
                    <div class="flex justify-between font-headline-md text-headline-md text-primary-fixed pt-2 border-t border-outline-variant">
                        <span>Total</span>
                        <span>$1,200.00</span>
                    </div>
                </div>
                <!-- Payment Methods -->
                <div class="mb-stack-md">
                    <span class="font-label-caps text-label-caps text-on-surface-variant block mb-2">Método de Pago</span>
                    <div class="flex bg-surface-container-highest rounded-lg p-1 border border-outline-variant">
                        <button class="flex-1 py-2 rounded flex flex-col items-center justify-center text-on-surface hover:text-primary-fixed transition-colors">
                            <span class="material-symbols-outlined text-[20px] mb-1">payments</span>
                            <span class="font-label-caps text-[10px]">Efectivo</span>
                        </button>
                        <button class="flex-1 py-2 bg-surface-container rounded shadow-sm flex flex-col items-center justify-center text-primary-fixed border border-primary-fixed/30 transition-colors">
                            <span class="material-symbols-outlined text-[20px] mb-1">credit_card</span>
                            <span class="font-label-caps text-[10px]">Tarjeta</span>
                        </button>
                        <button class="flex-1 py-2 rounded flex flex-col items-center justify-center text-on-surface hover:text-primary-fixed transition-colors">
                            <span class="material-symbols-outlined text-[20px] mb-1">account_balance</span>
                            <span class="font-label-caps text-[10px]">Transfer.</span>
                        </button>
                    </div>
                </div>
                <!-- Action Button -->
                <button class="w-full py-4 bg-primary-container text-on-primary-container rounded-lg font-headline-md text-headline-md hover:bg-surface-tint transition-all active:scale-[0.98] neon-glow flex justify-center items-center gap-2 cursor-pointer">
                    <span class="material-symbols-outlined">point_of_sale</span>
                    Procesar Pago
                </button>
            </div>
        </aside>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const url = 'https://script.google.com/macros/s/AKfycbz-5zbcyoNX5sSrVp39Ocj6NbTqIP7XSHLti5o2AfrOl5dcD_-6mf2ieLN2XkldklCNAQ/exec?action=catalogoMembresias';
            const grid = document.getElementById('membresias-grid');
            const otrosGrid = document.getElementById('otros-grid');
            const loading = document.getElementById('loading-pos');
            
            // Setup tabs
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.tab-btn').forEach(b => {
                        b.className = "tab-btn font-label-caps text-label-caps text-on-surface-variant hover:text-on-surface pb-2 px-2 transition-colors border-b-2 border-transparent";
                    });
                    const target = e.currentTarget as HTMLElement;
                    target.className = "tab-btn font-label-caps text-label-caps text-primary-fixed border-b-2 border-primary-fixed pb-2 px-2";

                    if(target.dataset.tab === 'membresias') {
                        grid.classList.remove('hidden');
                        otrosGrid.classList.add('hidden');
                    } else {
                        grid.classList.add('hidden');
                        otrosGrid.classList.remove('hidden');
                    }
                });
            });

            // Fetch memberships
            grid.classList.add('hidden');
            loading.classList.remove('hidden');

            try {
                const response = await fetch(url);
                const result = await response.json();

                if (result.exito) {
                    grid.innerHTML = '';
                    result.datos.forEach(membresia => {
                        const card = document.createElement('div');
                        card.className = "bg-surface-container rounded-xl border border-outline-variant p-4 flex flex-col hover:border-primary-fixed/50 transition-colors group";
                        
                        card.innerHTML = `
                            <div class="h-32 bg-surface-container-highest rounded-lg mb-4 flex items-center justify-center relative overflow-hidden">
                                <span class="material-symbols-outlined text-[48px] text-primary-fixed/30 group-hover:text-primary-fixed/70 transition-colors" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                                <div class="absolute top-2 right-2 bg-surface-container-low px-2 py-1 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant">
                                    SOLO VISTA
                                </div>
                            </div>
                            <h3 class="font-data-table text-data-table text-on-surface mb-1">${membresia.nombre}</h3>
                            <p class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex-1">Vigencia: ${membresia.duracion} días</p>
                            <div class="flex justify-between items-center mt-auto">
                                <span class="font-headline-md text-headline-md text-primary-fixed">$${membresia.precio}</span>
                                <span class="text-on-surface-variant text-xs font-label-caps">Inscribir en Menú</span>
                            </div>
                        `;
                        grid.appendChild(card);
                    });
                }
            } catch (err) {
                console.error("Error", err);
                grid.innerHTML = '<p class="text-error col-span-4">Error cargando membresías.</p>';
            } finally {
                loading.classList.add('hidden');
                grid.classList.remove('hidden'); // Show it since it's the active tab
            }
        });
    </script>
</DashboardLayout>
