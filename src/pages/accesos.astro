---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Control de Accesos">
    <div class="h-full flex flex-col">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="font-headline-lg text-headline-lg text-on-background mb-2">Control de Accesos</h1>
                <p class="font-body-md text-on-surface-variant">Monitoreo en tiempo real de entradas y salidas.</p>
            </div>
            <div class="flex gap-4">
                <div class="bg-surface-container border border-outline-variant rounded-lg p-4 flex flex-col items-center min-w-[120px]">
                    <span class="font-label-caps text-label-caps text-on-surface-variant mb-1">Aforo Actual</span>
                    <span class="font-metric-xl text-metric-xl text-primary-fixed">142</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-1 min-h-0">
            <!-- Feed de Accesos en Tiempo Real -->
            <div class="lg:col-span-2 flex flex-col gap-6 h-full">
                <!-- Mostrado Arriba del Feed (Generado dinámicamente) -->
                <div id="latest-scan" class="hidden bg-surface-container-high border border-primary-fixed/50 rounded-xl p-6 shadow-[0_0_20px_rgba(0,255,65,0.15)] flex items-center gap-6 relative overflow-hidden">
                    <div class="absolute left-0 top-0 w-1.5 h-full bg-primary-fixed"></div>
                    <div class="w-16 h-16 rounded-full bg-surface-container overflow-hidden border border-primary-fixed/30">
                        <div class="w-full h-full bg-[#1A1A1A] flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary-fixed text-3xl">person</span>
                        </div>
                    </div>
                    <div class="flex-1">
                        <h3 class="font-headline-md text-headline-md text-on-surface" id="latest-scan-name">Miembro Validado</h3>
                        <p class="font-label-caps text-label-caps text-primary-fixed mt-1" id="latest-scan-id">ID: KF-XXXX</p>
                    </div>
                    <div class="text-right flex flex-col items-end">
                        <div class="flex items-center gap-2 bg-primary-fixed/10 px-3 py-2 rounded-lg border border-primary-fixed/20 text-primary-fixed font-label-caps text-label-caps mb-1">
                            <span class="material-symbols-outlined">check_circle</span> ACCESO PERMITIDO
                        </div>
                        <span class="text-sm text-on-surface-variant">Justo ahora</span>
                    </div>
                </div>

                <div class="bg-surface-container border border-outline-variant rounded-xl flex flex-col overflow-hidden flex-1">
                    <div class="p-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-high">
                        <h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-primary-fixed animate-pulse"></span>
                            Ingresos del día de hoy
                        </h2>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px]">search</span>
                            <input type="text" placeholder="Buscar por ID o Nombre..." class="pl-9 pr-4 py-2 bg-surface-container-highest border border-outline-variant rounded-full text-sm text-on-surface focus:outline-none focus:border-primary-fixed w-64">
                        </div>
                    </div>
                    <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-3" id="access-feed">
                        <div class="text-center text-on-surface-variant py-4 flex flex-col items-center gap-2" id="loading-feed">
                            <span class="material-symbols-outlined animate-spin">progress_activity</span>
                            Cargando accesos de hoy...
                        </div>
                    </div>
                </div>
            </div>

            <!-- Entrada Manual -->
            <div class="flex flex-col gap-6">
                <div class="bg-surface-container border border-outline-variant rounded-xl p-6">
                    <h3 class="font-headline-md text-headline-md text-on-surface mb-4 border-b border-outline-variant pb-2">Entrada Manual</h3>
                    <form class="flex flex-col gap-4" id="manual-entry-form">
                        <div>
                            <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">ID de Miembro</label>
                            <input type="text" id="member-id-input" class="w-full bg-surface-container-highest border border-outline-variant rounded-lg px-4 py-3 text-on-surface focus:outline-none focus:border-primary-fixed focus:ring-1 focus:ring-primary-fixed font-data-table" placeholder="Ej. KF-1234" required>
                        </div>
                        <button type="submit" class="w-full py-3 bg-primary-container text-on-primary-container hover:bg-surface-tint rounded-lg font-label-caps text-label-caps transition-colors mt-2">
                            Registrar Ingreso
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('manual-entry-form');
            const input = document.getElementById('member-id-input') as HTMLInputElement;
            const latestScan = document.getElementById('latest-scan');
            const latestScanId = document.getElementById('latest-scan-id');
            const latestScanName = document.getElementById('latest-scan-name');
            const feed = document.getElementById('access-feed');
            const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

            const url = 'https://script.google.com/macros/s/AKfycbz-5zbcyoNX5sSrVp39Ocj6NbTqIP7XSHLti5o2AfrOl5dcD_-6mf2ieLN2XkldklCNAQ/exec';

            if (form && input && latestScan && latestScanId && feed) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const val = input.value.trim();
                    if (!val) return;

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Procesando...';

                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'text/plain;charset=utf-8'
                            },
                            body: JSON.stringify({
                                action: 'registrarAcceso',
                                idMiembro: val
                            })
                        });
                        const result = await response.json();

                        if (result.exito) {
                            const d = result.datos;
                            // Ahora validará correctamente contra lo que arroja tu Sheets
                            const isPermitido = d.estatus === "ACTIVO" || d.estatus === "PERMITIDO";
                            
                            // Top Banner Styling
                            latestScan.className = isPermitido 
                                ? "bg-surface-container-high border border-primary-fixed/50 rounded-xl p-6 shadow-[0_0_20px_rgba(0,255,65,0.15)] flex items-center gap-6 relative overflow-hidden"
                                : "bg-surface-container-high border border-error/50 rounded-xl p-6 shadow-[0_0_20px_rgba(255,84,73,0.15)] flex items-center gap-6 relative overflow-hidden";
                                
                            const leftBar = latestScan.querySelector('div.absolute');
                            if(leftBar) leftBar.className = isPermitido ? "absolute left-0 top-0 w-1.5 h-full bg-primary-fixed" : "absolute left-0 top-0 w-1.5 h-full bg-error";

                            const statusBox = latestScan.querySelector('.text-right div');
                            if(statusBox) {
                                statusBox.className = isPermitido
                                    ? "flex items-center gap-2 bg-primary-fixed/10 px-3 py-2 rounded-lg border border-primary-fixed/20 text-primary-fixed font-label-caps text-label-caps mb-1"
                                    : "flex items-center gap-2 bg-error/10 px-3 py-2 rounded-lg border border-error/20 text-error font-label-caps text-label-caps mb-1";
                                statusBox.innerHTML = isPermitido
                                    ? '<span class="material-symbols-outlined">check_circle</span> ACCESO PERMITIDO'
                                    : '<span class="material-symbols-outlined">block</span> ACCESO DENEGADO';
                            }
                            
                            // Update content
                            if(latestScanName) latestScanName.textContent = d.nombre;
                            latestScanId.textContent = `ID: ${val} • Restan: ${d.diasRestantes} días`;
                            latestScan.classList.remove('hidden');

                            // Add to Feed
                            const newEntry = document.createElement('div');
                            newEntry.className = isPermitido
                                ? "flex items-center gap-4 p-4 rounded-lg border border-primary-fixed/20 bg-primary-fixed/5"
                                : "flex items-center gap-4 p-4 rounded-lg border border-error/30 bg-error/5 relative overflow-hidden";
                            
                            const leftRedBar = isPermitido ? "" : `<div class="absolute left-0 top-0 w-1 h-full bg-error"></div>`;
                            const iconColor = isPermitido ? "border-primary-fixed/50" : "border-error/50";
                            
                            newEntry.innerHTML = `
                                ${leftRedBar}
                                <div class="w-12 h-12 rounded-full overflow-hidden border ${iconColor} flex-shrink-0">
                                    <div class="w-full h-full bg-[#1A1A1A] flex items-center justify-center">
                                        <span class="material-symbols-outlined text-outline-variant text-xl">person</span>
                                    </div>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-data-table text-data-table text-on-surface">${d.nombre}</h4>
                                    <p class="font-label-caps text-label-caps ${isPermitido ? 'text-on-surface-variant' : 'text-error'} mt-1">ID: ${val} • Días: ${d.diasRestantes}</p>
                                </div>
                                <div class="text-right flex flex-col items-end">
                                    <div class="flex items-center gap-1 ${isPermitido ? 'text-primary-fixed bg-primary-fixed/10' : 'text-error bg-error-container/20 border-error/20 border'} px-2 py-1 rounded font-label-caps text-label-caps mb-1">
                                        <span class="material-symbols-outlined text-[14px]">${isPermitido ? 'check_circle' : 'block'}</span>
                                        ${d.estatus}
                                    </div>
                                    <span class="text-xs text-on-surface-variant">Justo ahora</span>
                                    ${!isPermitido ? `<a href="/renovacion?id=${val}" class="text-xs text-primary-fixed hover:underline flex items-center gap-1 mt-1">Gestionar <span class="material-symbols-outlined text-[12px]">arrow_forward</span></a>` : ''}
                                </div>
                            `;
                            feed.prepend(newEntry);
                        } else {
                            alert(result.mensaje);
                        }
                    } catch (err) {
                        alert("Error de conexión");
                        console.error(err);
                    } finally {
                        input.value = '';
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = 'Registrar Ingreso';
                    }
                });

                // Cargar accesos de hoy al iniciar
                async function obtenerAccesosDeHoy() {
                    try {
                        const response = await fetch(`${url}?action=obtenerAccesosDeHoy`);
                        const result = await response.json();
                        
                        const loadingElement = document.getElementById('loading-feed');
                        if (loadingElement) loadingElement.remove();
                        
                        if (result.exito && result.datos && result.datos.length > 0) {
                            result.datos.forEach((d: any) => {
                                const isPermitido = d.estatus === "PERMITIDO" || d.estatus === "ACTIVO";
                                const estatusMostrar = isPermitido ? "PERMITIDO" : "DENEGADO";
                                
                                const newEntry = document.createElement('div');
                                newEntry.className = isPermitido
                                    ? "flex items-center gap-4 p-4 rounded-lg border border-primary-fixed/20 bg-primary-fixed/5"
                                    : "flex items-center gap-4 p-4 rounded-lg border border-error/30 bg-error/5 relative overflow-hidden";
                                
                                const leftRedBar = isPermitido ? "" : `<div class="absolute left-0 top-0 w-1 h-full bg-error"></div>`;
                                const iconColor = isPermitido ? "border-primary-fixed/50" : "border-error/50";
                                
                                // Parsear la hora
                                let horaMostrar = d.hora || 'Hace unos momentos';

                                newEntry.innerHTML = `
                                    ${leftRedBar}
                                    <div class="w-12 h-12 rounded-full overflow-hidden border ${iconColor} flex-shrink-0">
                                        <div class="w-full h-full bg-[#1A1A1A] flex items-center justify-center">
                                            <span class="material-symbols-outlined text-outline-variant text-xl">person</span>
                                        </div>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-data-table text-data-table text-on-surface">${d.nombre || 'Desconocido'}</h4>
                                        <p class="font-label-caps text-label-caps ${isPermitido ? 'text-on-surface-variant' : 'text-error'} mt-1">ID: ${d.idMiembro || d.id || ''} ${d.diasRestantes !== undefined ? '• Restan: ' + d.diasRestantes + ' días' : ''}</p>
                                    </div>
                                    <div class="text-right flex flex-col items-end">
                                        <div class="flex items-center gap-1 ${isPermitido ? 'text-primary-fixed bg-primary-fixed/10' : 'text-error bg-error-container/20 border-error/20 border'} px-2 py-1 rounded font-label-caps text-label-caps mb-1">
                                            <span class="material-symbols-outlined text-[14px]">${isPermitido ? 'check_circle' : 'block'}</span>
                                            ${estatusMostrar}
                                        </div>
                                        <span class="text-xs text-on-surface-variant">${horaMostrar}</span>
                                        ${!isPermitido ? `<a href="/renovacion?id=${d.idMiembro || d.id || ''}" class="text-xs text-primary-fixed hover:underline flex items-center gap-1 mt-1">Gestionar <span class="material-symbols-outlined text-[12px]">arrow_forward</span></a>` : ''}
                                    </div>
                                `;
                                feed.appendChild(newEntry);
                            });
                        } else if (result.datos && result.datos.length === 0) {
                            feed.innerHTML = '<div class="text-center text-on-surface-variant py-4">No hay accesos registrados hoy.</div>';
                        }
                    } catch (err) {
                        console.error("Error al obtener accesos de hoy:", err);
                        feed.innerHTML = '<div class="text-center text-error py-4">Error al cargar los accesos.</div>';
                    }
                }

                obtenerAccesosDeHoy();
            }
        });
    </script>
</DashboardLayout>
